# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Public site URL for SEO canonicals (production Codex host)
# VITE_PUBLIC_SITE_URL=https://codex.itsnomatata.com

# LiveKit meetings (optional — falls back to edge function URL)
# VITE_LIVEKIT_URL=wss://meet.itsnomatata.com

# ── Browser push (Web Push / VAPID) ─────────────────────────────────────────
# 1. Generate keys:  npm run generate:vapid-keys
# 2. Paste the public key below (frontend only).
# 3. In Supabase Dashboard → Project Settings → Edge Functions → Secrets, set:
#      VAPID_PUBLIC_KEY   (same as below)
#      VAPID_PRIVATE_KEY  (from generate command — never commit)
#      VAPID_SUBJECT=mailto:your-team@itsnomatata.com
# 4. Redeploy:  supabase functions deploy send-push-notification
# 5. In the app: Settings → Browser push → Enable on this device
#    (requires HTTPS or localhost)
VITE_VAPID_PUBLIC_KEY=

# Optional override for client change-request emails (default: tammie@itsnomatata.com)
# VITE_CONTENT_STUDIO_FINAL_REVIEWER_EMAIL=tammie@itsnomatata.com

# Email notifications — configure ONLY on Supabase Edge secrets (never in VITE_*):
# Resend direct email provider (default/recommended):
#   EMAIL_PROVIDER=resend
#   RESEND_API_KEY=re_xxxxxxxxx
#   RESEND_FROM_EMAIL=Codex <notifications@your-verified-domain.com>
#   RESEND_REPLY_TO_EMAIL=support@your-domain.com
#
# Optional n8n workflow provider (only if EMAIL_PROVIDER=n8n):
#   EMAIL_PROVIDER=n8n
#   N8N_NOTIFICATION_WEBHOOK_URL
#   N8N_NOTIFICATION_WEBHOOK_SECRET
#   INTERNAL_API_KEY  (long random; used by create-notification, cron jobs, n8n)
# App sends email through the send-direct-email edge function (authenticated).

# AI / automation webhooks (optional)
# VITE_N8N_AI_WEBHOOK_URL=
# VITE_N8N_AI_CHAT_WEBHOOK=
# Optional local-only debug logging for redacted API payloads.
# VITE_DEBUG_API_LOGS=false
#
# Do not add n8n secrets or private API keys as VITE_* variables.

# Chat GIF search (optional)
# VITE_GIPHY_API_KEY=
# VITE_TENOR_API_KEY=
