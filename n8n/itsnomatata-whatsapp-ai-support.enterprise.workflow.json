    {
      "parameters": {
        "jsCode": "const item = $json;\nconst text = (item.text || '').toLowerCase();\nconst original = item.originalMessage || item.text || '';\nconst includesAny = (terms) => terms.some((term) => text.includes(term));\nlet detectedIntent = 'unknown';\nlet priority = 'normal';\nlet confidence = 0.55;\nlet escalationRequired = false;\n\nif (includesAny(['video link', 'did not receive', \"haven't received\", 'missing video', 'media centre', 'media center', 'purchased a video', 'bought a video'])) {\n  detectedIntent = 'missing_video'; priority = 'high'; confidence = 0.9; escalationRequired = true;\n} else if (includesAny(['complaint', 'unhappy', 'angry', 'bad service', 'not happy', 'disappointed', 'refund'])) {\n  detectedIntent = 'complaint'; priority = 'high'; confidence = 0.85; escalationRequired = true;\n} else if (includesAny(['call me', 'callback', 'phone me', 'ring me', 'speak to someone'])) {\n  detectedIntent = 'callback_request'; priority = 'high'; confidence = 0.9; escalationRequired = true;\n} else if (includesAny(['codex', 'ai bot', 'assistant', 'workflow', 'automation', 'platform error', 'system issue', 'agent not replying', 'bot'])) {\n  detectedIntent = 'codex_system_issue'; priority = 'high'; confidence = 0.85; escalationRequired = true;\n} else if (includesAny(['invoice', 'payment', 'paid', 'billing', 'quote', 'price', 'cost', 'receipt'])) {\n  detectedIntent = 'billing'; priority = 'normal'; confidence = 0.75; escalationRequired = true;\n} else if (includesAny(['website down', 'error', 'bug', 'login', 'not working', 'broken', 'technical'])) {\n  detectedIntent = 'technical_support'; priority = 'high'; confidence = 0.75; escalationRequired = true;\n} else if (includesAny(['package', 'service', 'marketing', 'website design', 'social media', 'seo', 'advertising', 'proposal'])) {\n  detectedIntent = 'sales'; priority = 'normal'; confidence = 0.7; escalationRequired = true;\n} else if (includesAny(['human', 'person', 'support team'])) {\n  detectedIntent = 'human_handoff'; priority = 'high'; confidence = 0.8; escalationRequired = true;\n} else if (includesAny(['website', 'link', 'url', 'page'])) {\n  detectedIntent = 'website_question'; confidence = 0.7;\n} else if (text.trim().length > 0) {\n  detectedIntent = 'faq'; confidence = 0.65;\n}\n\nif (detectedIntent === 'unknown' || confidence < 0.6 || item.messageType === 'unsupported') {\n  escalationRequired = true;\n}\n\nconst emailRegex = /[A-Z0-9._%+-]+@[A-Z0-9.-]+\\.[A-Z]{2,}/i;\nconst dateRegex = /\\b(\\d{1,2}[\\/\\-]\\d{1,2}[\\/\\-]\\d{2,4}|\\d{4}[\\/\\-]\\d{1,2}[\\/\\-]\\d{1,2}|today|yesterday|tomorrow)\\b/i;\nconst hasEmail = emailRegex.test(original);\nconst hasActivityDate = dateRegex.test(original);\nconst hasCustomerName = item.customerName && item.customerName !== 'Unknown Customer';\nconst missingVideoDetailsComplete = detectedIntent !== 'missing_video' || (hasEmail && hasActivityDate && hasCustomerName && item.whatsappNumber);\n\nreturn [{ json: {\n  ...item,\n  detectedIntent,\n  priority,\n  confidence,\n  escalationRequired,\n  missingVideoDetailsComplete,\n  extractedCustomerEmail: (original.match(emailRegex) || [''])[0],\n  extractedActivityDate: (original.match(dateRegex) || [''])[0]\n}}];"
      },
