      "parameters": {
        "jsCode": "const root = $('01 WhatsApp Trigger').item.json;\nconst message = root.messages?.[0] || {};\nconst contact = root.contacts?.[0] || {};\nconst caption = message.image?.caption || '';\nconst imageDescription = $json.content || $json.text || 'Image received, but no description was generated.';\nconst combined = '# User image context\\n' + imageDescription + '\\n\\n# User caption/message\\n' + (caption || 'No caption provided.');\nreturn [{ json: {\n  messageType: 'image',\n  text: combined,\n  originalMessage: caption || 'Customer sent an image without text.',\n  customerName: contact.profile?.name || 'Unknown Customer',\n  whatsappNumber: message.from || '',\n  timestamp: new Date((Number(message.timestamp) || Math.floor(Date.now() / 1000)) * 1000).toISOString(),\n  mediaContext: imageDescription,\n  mediaId: message.image?.id || '',\n  hasMedia: true\n}}];"
