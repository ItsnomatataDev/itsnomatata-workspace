    {
      "parameters": {
        "jsCode": "const j = $json;\nlet emailTo = 'support@itsnomatata.com';\nlet emailCc = '';\nlet subjectPrefix = 'New WhatsApp Support Request';\n\nif (j.detectedIntent === 'missing_video') {\n  emailTo = 'media@itsnomatata.com';\n  emailCc = 'ben@itsnomatata.com';\n  subjectPrefix = 'Missing Video Link Request';\n} else if (j.detectedIntent === 'codex_system_issue') {\n  emailTo = 'codex@itsnomatata.com';\n  subjectPrefix = 'Codex System Support Request';\n} else if (j.detectedIntent === 'complaint') {\n  subjectPrefix = 'Customer Complaint';\n} else if (j.detectedIntent === 'callback_request') {\n  subjectPrefix = 'Callback Request';\n} else if (j.detectedIntent === 'unknown') {\n  emailCc = 'codex@itsnomatata.com';\n}\n\nconst recommendedNextStep = j.detectedIntent === 'missing_video'\n  ? 'Media team should locate the purchased video link and follow up with the customer.'\n  : j.detectedIntent === 'callback_request'\n    ? 'Support team should call or WhatsApp the customer as soon as possible.'\n    : j.detectedIntent === 'codex_system_issue'\n      ? 'Codex/system support should investigate the AI/platform issue and update the customer or support team.'\n      : j.detectedIntent === 'complaint'\n        ? 'Support lead should review the complaint and contact the customer promptly.'\n        : 'Support team should review the request and follow up with the customer.';\n\nconst emailSubject = subjectPrefix + ' - ' + (j.customerName || 'Unknown Customer');\nconst emailBody = [\n  'Customer Name:', j.customerName || 'Unknown Customer', '',\n  'WhatsApp Number:', j.whatsappNumber || 'Unknown', '',\n  'Detected Intent:', j.detectedIntent, '',\n  'Priority:', j.priority, '',\n  'Timestamp:', j.timestamp, '',\n  'Original Message:', j.originalMessage || j.text || '', '',\n  'AI Summary:', j.aiResponse || 'No AI summary generated.', '',\n  'Media/Image/Audio Context:', j.mediaContext || 'None', '',\n  'Recommended Next Step:', recommendedNextStep\n].join('\\n');\n\nreturn [{ json: { ...j, emailTo, emailCc, emailSubject, emailBody, recommendedNextStep } }];"
