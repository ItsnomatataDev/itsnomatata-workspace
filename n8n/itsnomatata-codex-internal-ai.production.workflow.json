        "jsCode": "const output = $json.output || $json.message || $json.text || 'I could not produce a verified response.';\nreturn [{ json: {\n  success: true,\n  type: 'text',\n  message: output,\n  output,\n  conversationId: $('04 Merge Request + User Context').first().json.conversationId || null,\n  data: {},\n  sources: $json.sources || []\n}}];"
