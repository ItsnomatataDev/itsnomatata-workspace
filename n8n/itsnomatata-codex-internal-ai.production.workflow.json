          "value": "gpt-4o-mini",
          "mode": "list",
          "cachedResultName": "gpt-4o-mini"
        },
        "messages": {
          "values": [
            {
              "content": "={{ 'Summarize this company knowledge chunk for retrieval. Return concise summary, key points, actions, deadlines, owners, departments, risks, and tags.\\n\\nChunk:\\n' + $json.chunkText }}"
            }
          ]
        },
        "options": {}
