    {
      "id": "clean-and-chunk",
      "name": "Clean and Chunk Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -600,
        1160
      ],
      "parameters": {
        "jsCode": "const raw = $json.text || $json.data || '';\nconst text = String(raw).replace(/\\s+/g, ' ').trim();\nif (!text) throw new Error('Document could not be read. Please upload a readable file or OCR version.');\nconst chunkSize = 2200;\nconst overlap = 180;\nconst chunks = [];\nfor (let i = 0; i < text.length; i += chunkSize - overlap) {\n  chunks.push({ json: { ...$json, chunkIndex: chunks.length, chunkText: text.slice(i, i + chunkSize) } });\n}\nreturn chunks;"
      }
    },
    {
      "id": "summarize-chunk-openai",
      "name": "Summarize Chunk - OpenAI",
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 1.8,
      "position": [
        -360,
        1160
      ],
      "parameters": {
        "modelId": {
