{
  "name": "ITsNomatata Codex Internal AI - Production Blueprint",
  "meta": {
    "description": "Production-ready n8n blueprint for Codex: chat agent, document training, document Q&A, people directory, web research, image fetch, code assistant, OpenAI primary model, Gemini backup model.",
    "openAiPrimary": true,
    "geminiBackup": true,
    "doNotUseClaude": true
  },
  "nodes": [
    {
      "id": "chat-trigger",
      "name": "01 Chat Trigger - Frontend or n8n Chat",
      "type": "@n8n/n8n-nodes-langchain.chatTrigger",
      "typeVersion": 1.1,
      "position": [
        -1800,
        0
      ],
      "parameters": {
        "public": true,
        "mode": "webhook",
        "options": {}
      }
    },
    {
      "id": "normalize-chat-payload",
      "name": "02 Normalize Chat Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1560,
        0
      ],
      "parameters": {
        "jsCode": "const body = $json;\nconst chatInput = body.chatInput || body.message || body.text || body.output || '';\nreturn [{ json: {\n  ...body,\n  chatInput,\n  message: chatInput,\n  sessionId: body.sessionId || body.conversationId || body.context?.userId || 'anonymous',\n  conversationId: body.conversationId || null,\n  context: body.context || {},\n  metadata: body.metadata || {},\n  attachments: body.attachments || [],\n  action: body.action || 'sendMessage'\n}}];"
      }
    },
    {
      "id": "load-user-context",
      "name": "03 Prepare User Context (Supabase Optional)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1320,
        0
      ],
      "parameters": {
        "jsCode": "const request = $('02 Normalize Chat Payload').first().json;\nconst context = request.context || {};\n\n// This node is intentionally local-first. n8n on this server blocks $env,\n// and $vars may be empty during manual tests. The frontend already sends\n// user context, so do not crash the workflow when Supabase enrichment is\n// not configured yet.\nreturn [{ json: {\n  ...request,\n  profile: {\n    id: context.userId || null,\n    full_name: context.fullName || null,\n    email: context.email || null,\n    primary_role: context.role || 'employee',\n    department: context.department || null,\n    organization_id: context.organizationId || null\n  },\n  supabaseContextStatus: context.userId ? 'frontend_context' : 'anonymous_or_manual_test'\n}}];"
      }
    },
    {
      "id": "merge-context",
      "name": "04 Merge Request + User Context",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1080,
        0
      ],
      "parameters": {
        "jsCode": "const request = $('03 Prepare User Context (Supabase Optional)').first().json;\nconst profile = request.profile || {};\nconst chatInput = request.chatInput || request.message || '';\nreturn [{ json: {\n  ...request,\n  chatInput,\n  message: chatInput,\n  context: {\n    ...request.context,\n    userId: request.context.userId || profile.id || 'anonymous',\n    fullName: request.context.fullName || profile.full_name || 'Workspace User',\n    email: request.context.email || profile.email || null,\n    role: request.context.role || profile.primary_role || 'employee',\n    department: request.context.department || profile.department || null,\n    organizationId: request.context.organizationId || profile.organization_id || 'workspace-default',\n    currentModule: request.context.currentModule || 'ai-workspace',\n    timezone: request.context.timezone || 'Africa/Harare',\n    channel: request.context.channel || 'web'\n  }\n}}];"
      }
    },
    {
      "id": "permission-router",
      "name": "05 Permission + Tool Router",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -840,
        0
      ],
      "parameters": {
        "jsCode": "const chatInput = $json.chatInput || $json.message || '';\nconst message = chatInput.toLowerCase();\nconst attachments = $json.attachments || [];\nlet route = 'main_agent';\nif (attachments.length || /document|file|pdf|policy|summarize this|action items|deadline/.test(message)) route = 'document_qa';\nif (/who|team|department|responsible|maintain|built codex|developer/.test(message)) route = 'people_directory';\nif (/website|external company|research|find online|official site/.test(message)) route = 'web_research';\nif (/logo|image|hero image|gallery|open graph|og:image|favicon/.test(message)) route = 'image_fetch';\nif (/code|typescript|react|next|tailwind|supabase|node|expo|bug|error/.test(message)) route = 'code_assistant';\nreturn [{ json: { ...$json, chatInput, message: chatInput, route, allowed: true } }];"
      }
    },
