    {
      "id": "final-document-summary",
      "name": "Create Final Document Summary",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -120,
        1160
      ],
      "parameters": {
        "jsCode": "const summaries = items.map(item => item.json.message?.content || item.json.output || '').filter(Boolean);\nreturn [{ json: {\n  summary_short: summaries[0]?.slice(0, 400) || '',\n  summary_detailed: summaries.join('\\n\\n'),\n  tags: [],\n  status: 'trained',\n  chunks: items.map((item, index) => ({ index, summary: item.json.message?.content || '', text: item.json.chunkText || '' }))\n}}];"
      }
    },
